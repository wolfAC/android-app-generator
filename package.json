{
  "name": "twa-generator",
  "version": "1.0.0",
  "description": "Generate complete Android TWA (Trusted Web Activity) projects from a config file",
  "main": "src/generator.js",
  "bin": {
    "twa-generator": "./bin/twa-generator.js"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ bin/",
    "start": "node bin/twa-generator.js"
  },
  "keywords": [
    "android",
    "twa",
    "trusted-web-activity",
    "pwa",
    "android-studio",
    "gradle",
    "kotlin"
  ],
  "author": "TWA Generator",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "ora": "^5.4.1",
    "semver": "^7.6.3",
    "sharp": "^0.33.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ]
  }
}
