package <%= packageName %>

<%  if (features.notifications && firebase && firebase.enabled) { %>
import com.google.firebase.messaging.FirebaseMessagingService
import com.google.firebase.messaging.RemoteMessage

/**
 * MyFirebaseMessagingService — handles incoming FCM push notifications.
 *
 * Delegates notification display to [NotificationHelper] and token storage
 * to [FirebaseTokenManager].
 */
class MyFirebaseMessagingService : FirebaseMessagingService() {

    override fun onMessageReceived(remoteMessage: RemoteMessage) {
        super.onMessageReceived(remoteMessage)

        // Handle data payload
        if (remoteMessage.data.isNotEmpty()) {
            // Process data message here if needed
        }

        // Handle notification payload
        remoteMessage.notification?.let { notification ->
            val clickUrl = remoteMessage.data["url"] ?: "<%= websiteUrl %>"
            NotificationHelper.showNotification(
                context = this,
                title = notification.title ?: "<%= appName %>",
                body = notification.body ?: "",
                clickUrl = clickUrl,
                channelId = NotificationHelper.CHANNEL_ID_DEFAULT
            )
        }
    }

    override fun onNewToken(token: String) {
        super.onNewToken(token)
        FirebaseTokenManager.saveToken(this, token)
        // TODO: Send the new token to your server
    }
}
<%  } else { %>
// Firebase Messaging Service is disabled.
// To enable it, set features.notifications = true and firebase.enabled = true in app.json,
// then regenerate the project.
//
// When enabled, this file will contain the full FirebaseMessagingService implementation
// for handling push notifications from Firebase Cloud Messaging (FCM).
<%  } %>
