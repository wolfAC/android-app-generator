package <%= packageName %>

import android.app.NotificationChannel
import android.app.NotificationManager
import android.app.PendingIntent
import android.content.Context
import android.content.Intent
import android.os.Build
import androidx.core.app.NotificationCompat

/**
 * NotificationHelper — manages notification channels and displays notifications.
 *
 * Creates two channels:
 *  - [CHANNEL_ID_DEFAULT]: high importance with sound and vibration
 *  - [CHANNEL_ID_SILENT]: low importance, no sound
 */
object NotificationHelper {

    const val CHANNEL_ID_DEFAULT = "default"
    const val CHANNEL_ID_SILENT = "silent"

    private const val CHANNEL_NAME_DEFAULT = "Default Notifications"
    private const val CHANNEL_NAME_SILENT = "Silent Notifications"

    fun createChannels(context: Context) {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            val nm = context.getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager

            val defaultChannel = NotificationChannel(
                CHANNEL_ID_DEFAULT,
                CHANNEL_NAME_DEFAULT,
                NotificationManager.IMPORTANCE_HIGH
            ).apply {
                description = "High priority notifications with sound and vibration"
                enableVibration(true)
                enableLights(true)
            }

            val silentChannel = NotificationChannel(
                CHANNEL_ID_SILENT,
                CHANNEL_NAME_SILENT,
                NotificationManager.IMPORTANCE_LOW
            ).apply {
                description = "Silent notifications without sound"
                enableVibration(false)
                setSound(null, null)
            }

            nm.createNotificationChannel(defaultChannel)
            nm.createNotificationChannel(silentChannel)
        }
    }

    fun showNotification(
        context: Context,
        title: String,
        body: String,
        clickUrl: String,
        channelId: String = CHANNEL_ID_DEFAULT
    ) {
        val intent = Intent(context, WebViewActivity::class.java).apply {
            addFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP or Intent.FLAG_ACTIVITY_SINGLE_TOP)
            putExtra(WebViewActivity.EXTRA_URL, clickUrl)
        }

        val pendingIntent = PendingIntent.getActivity(
            context,
            System.currentTimeMillis().toInt(),
            intent,
            PendingIntent.FLAG_ONE_SHOT or PendingIntent.FLAG_IMMUTABLE
        )

        val builder = NotificationCompat.Builder(context, channelId)
            .setSmallIcon(R.drawable.ic_notification)
            .setContentTitle(title)
            .setContentText(body)
            .setAutoCancel(true)
            .setContentIntent(pendingIntent)
            .setPriority(
                if (channelId == CHANNEL_ID_DEFAULT) NotificationCompat.PRIORITY_HIGH
                else NotificationCompat.PRIORITY_LOW
            )

        if (body.length > 50) {
            builder.setStyle(NotificationCompat.BigTextStyle().bigText(body))
        }

        val nm = context.getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager
        nm.notify(System.currentTimeMillis().toInt(), builder.build())
    }

    fun cancelAll(context: Context) {
        val nm = context.getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager
        nm.cancelAll()
    }
}
