<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration for <%= appName %>.

  Production: HTTPS only (no cleartext).
  Debug: allows cleartext for localhost/10.0.2.2 (Android emulator).

  See: https://developer.android.com/training/articles/security-config
-->
<network-security-config>

    <!-- Debug: allow cleartext to localhost for development -->
    <debug-overrides>
        <trust-anchors>
            <!-- Trust system CAs -->
            <certificates src="system" />
            <!-- Trust user-installed CAs in debug (e.g., Charles/Fiddler proxy) -->
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

    <!-- Production: HTTPS required for the app's domain -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true"><%= new URL(websiteUrl).hostname %></domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Allow cleartext for local development addresses -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
        <domain includeSubdomains="false">192.168.0.0</domain>
    </domain-config>

    <!-- Base config: trust system CAs, no cleartext in production -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>
