{
  "project_info": {
    "project_number": "<%= firebase.messagingSenderId || 'REPLACE_WITH_YOUR_PROJECT_NUMBER' %>",
    "project_id": "<%= firebase.projectId || 'REPLACE_WITH_YOUR_PROJECT_ID' %>",
    "storage_bucket": "<%= firebase.storageBucket || (firebase.projectId ? firebase.projectId + '.appspot.com' : 'REPLACE_WITH_YOUR_PROJECT_ID.appspot.com') %>"
  },
  "client": [
    {
      "client_info": {
        "mobilesdk_app_id": "<%= firebase.appId || 'REPLACE_WITH_YOUR_APP_ID' %>",
        "android_client_info": {
          "package_name": "<%= packageName %>"
        }
      },
      "oauth_client": [],
      "api_key": [
        {
          "current_key": "<%= firebase.apiKey || 'REPLACE_WITH_YOUR_API_KEY' %>"
        }
      ],
      "services": {
        "appinvite_service": {
          "other_platform_oauth_client": []
        }
      }
    }
  ],
  "configuration_version": "1"
}
